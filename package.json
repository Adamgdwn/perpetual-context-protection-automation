{
  "name": "perpetual-context-protection-automation",
  "displayName": "Perpetual Context Protection Automation",
  "description": "Desktop operator app, VS Code companion extension, and local bridge for managed AI coding sessions.",
  "version": "0.0.1",
  "private": true,
  "publisher": "adamgoodwin",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.125.0",
    "node": ">=24.14.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/src/extension/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:pcpa.sendHeartbeat",
    "onCommand:pcpa.startManagedClaude",
    "onCommand:pcpa.startManagedCodex",
    "onCommand:pcpa.runManagedIoProof",
    "onCommand:pcpa.sendTextToManagedSession"
  ],
  "contributes": {
    "configuration": {
      "title": "Perpetual Context Protection",
      "properties": {
        "pcpa.bridgeUrl": {
          "type": "string",
          "default": "http://127.0.0.1:47320",
          "description": "Localhost URL for the Perpetual Context Protection bridge."
        },
        "pcpa.heartbeatIntervalMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "description": "How often the VS Code companion extension sends a bridge heartbeat."
        }
      }
    },
    "commands": [
      {
        "command": "pcpa.sendHeartbeat",
        "title": "Perpetual Context Protection: Send Heartbeat"
      },
      {
        "command": "pcpa.startManagedClaude",
        "title": "Perpetual Context Protection: Start Managed Claude Session"
      },
      {
        "command": "pcpa.startManagedCodex",
        "title": "Perpetual Context Protection: Start Managed Codex Session"
      },
      {
        "command": "pcpa.runManagedIoProof",
        "title": "Perpetual Context Protection: Run Managed I/O Proof"
      },
      {
        "command": "pcpa.sendTextToManagedSession",
        "title": "Perpetual Context Protection: Send Text To Managed Session"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "lint": "eslint src test vite.desktop.config.mts",
    "test": "npm run compile && node --test dist/test/unit/*.test.js",
    "test:signal": "npm run compile && node --test dist/test/unit/signal-detector.test.js",
    "test:vscode": "npm run compile && xvfb-run -a node dist/test/vscode/runTest.js",
    "build": "npm run compile && vite build --config vite.desktop.config.mts",
    "desktop:launch": "npm run build && electron dist/src/desktop/main.js",
    "desktop:smoke": "npm run build && xvfb-run -a electron dist/src/desktop/main.js --smoke",
    "desktop:install-linux-launcher": "bash scripts/install-linux-desktop-launcher.sh"
  },
  "dependencies": {
    "lucide-react": "^1.22.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.125.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vscode/test-electron": "^3.0.0",
    "electron": "^42.5.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.0"
  }
}
